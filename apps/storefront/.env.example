# =============================================================================
# Mercado Preto — Storefront (Next.js)
#
# Variáveis prefixadas com NEXT_PUBLIC_ são expostas ao browser.
# NÃO coloque segredos nessas variáveis — qualquer usuário pode inspecioná-las.
#
# PRODUÇÃO:
#   - Nunca commite este arquivo. Adicione .env.local ao .gitignore.
#   - Configure as vars de produção no painel do provedor de deploy
#     (Vercel: Settings → Environment Variables).
# =============================================================================

# -----------------------------------------------------------------------------
# URL do backend Medusa [OBRIGATÓRIO]
#
# O storefront faz chamadas server-side e client-side para esta URL.
# Dev local:  http://localhost:9000
# Produção:   https://teste.mercadopreto.com.br/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# Publishable API Key do Medusa [OBRIGATÓRIO]
#
# Identifica o Sales Channel "Default" para todas as requisições da loja.
# Obtida em: Medusa Admin → Settings → API Keys → Publishable Keys
# Este valor é público (exposto ao browser) — não é um segredo.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PUBLISHABLE_KEY=pk_...    # Medusa Admin → Settings → API Keys

# -----------------------------------------------------------------------------
# Region ID do Medusa [OBRIGATÓRIO]
#
# Define a região de vendas (moeda BRL, país BR).
# Obtida em: Medusa Admin → Settings → Regions → Brasil → copiar o ID da URL
# Formato: reg_XXXXXXXXXXXXXXXXXXXXXXX
# -----------------------------------------------------------------------------
NEXT_PUBLIC_REGION_ID=reg_...           # Medusa Admin → Settings → Regions

# -----------------------------------------------------------------------------
# MercadoPago — Public Key [OBRIGATÓRIO para checkout]
#
# Usada pelo Checkout Bricks (frontend) para tokenizar cartões com segurança.
# REGRA CRÍTICA: deve ter o mesmo prefixo que MERCADOPAGO_ACCESS_TOKEN no backend.
#   TEST-*    → sandbox (use com access token TEST- no backend)
#   APP_USR-* → produção (use com access token APP_USR- no backend)
#
# Obter em: https://www.mercadopago.com.br/developers/panel/app
#   → Selecione o app → Credenciais de teste / Credenciais de produção → Chave pública
#
# Chave sandbox atual (par com o access token TEST- do backend):
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-...   # sandbox

# Chave produção (APP_USR-) — descomentar ao ir para produção.
# Lembre de trocar também MERCADOPAGO_ACCESS_TOKEN no backend .env.
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-... # produção

# -----------------------------------------------------------------------------
# Chatwoot — widget de atendimento ao cliente [OPCIONAL]
#
# Exibe um chat flutuante na loja para suporte em tempo real.
# Sem estas vars (ou com valores vazios), o widget não é renderizado.
#
# NEXT_PUBLIC_CHATWOOT_URL:   URL da instância Chatwoot (cloud ou self-hosted)
#   Ex: https://app.chatwoot.com
# NEXT_PUBLIC_CHATWOOT_TOKEN: token do inbox do tipo "Website" criado no Chatwoot
#   Obter em: Chatwoot → Settings → Inboxes → [nome do inbox] → Configuration → Website Token
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CHATWOOT_URL=
NEXT_PUBLIC_CHATWOOT_TOKEN=
