# =============================================================================
# Mercado Preto — Storefront (Next.js 15)
# Copie este arquivo para .env.local e preencha os valores.
# Vars NEXT_PUBLIC_* são expostas ao browser — nunca coloque segredos aqui.
# =============================================================================

# -----------------------------------------------------------------------------
# Medusa Backend [OBRIGATÓRIO]
# URL base da API do backend (sem barra final).
# Em produção: https://api.mercadopreto.com.br
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# Publishable API Key [OBRIGATÓRIO]
# Gerada no painel Admin → Settings → API Keys → Publishable Keys.
# Necessária para chamadas ao /store/* da API Medusa.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Chatwoot — widget de chat ao vivo [OPCIONAL]
# Sem estas vars, o widget não é carregado (nenhum script externo).
# NEXT_PUBLIC_CHATWOOT_URL: URL da sua instância Chatwoot (ex: https://chat.mercadopreto.com.br)
# NEXT_PUBLIC_CHATWOOT_TOKEN: Website Token do inbox configurado no Chatwoot
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CHATWOOT_URL=
NEXT_PUBLIC_CHATWOOT_TOKEN=
