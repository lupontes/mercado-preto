# =============================================================================
# Mercado Preto — Infraestrutura (docker-compose.prod.yml)
# Copie para infra/.env e preencha antes de subir o ambiente de produção.
# NUNCA comite o arquivo .env — apenas .env.template vai ao git.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados PostgreSQL [OBRIGATÓRIO]
# Gere uma senha forte: openssl rand -base64 24
# -----------------------------------------------------------------------------
DB_USER=medusa
DB_PASSWORD=troque_por_senha_forte
DB_NAME=mercado_preto

# -----------------------------------------------------------------------------
# Redis [OBRIGATÓRIO]
# Gere uma senha forte: openssl rand -base64 24
# -----------------------------------------------------------------------------
REDIS_PASSWORD=troque_por_senha_forte

# -----------------------------------------------------------------------------
# Meilisearch [OBRIGATÓRIO]
# Essa chave é o MEILI_MASTER_KEY e também o MEILISEARCH_API_KEY do backend.
# Gere: openssl rand -hex 32
# -----------------------------------------------------------------------------
MEILI_MASTER_KEY=troque_por_chave_aleatoria

# -----------------------------------------------------------------------------
# Segurança do Medusa [OBRIGATÓRIO]
# Gere: openssl rand -hex 32 (para cada um)
# -----------------------------------------------------------------------------
JWT_SECRET=troque_por_string_aleatoria
COOKIE_SECRET=troque_por_outra_string_aleatoria

# -----------------------------------------------------------------------------
# Modo sandbox — controla o comportamento de negócio de TODAS as integrações
# SaaS (MercadoPago, Focus NFe, Melhor Envio, Brevo, Evolution/WhatsApp).
# Ausente ou qualquer valor != "false" = sandbox (nenhum efeito real). Só
# "false" libera comportamento de produção. Ver src/utils/validate-env.ts —
# o backend recusa subir se MERCADOPAGO_ACCESS_TOKEN/FOCUS_NFE_SANDBOX não
# baterem com este modo.
# -----------------------------------------------------------------------------
MARKETPLACE_SANDBOX=true

# -----------------------------------------------------------------------------
# CORS — domínios do frontend [OBRIGATÓRIO]
# Substitua pelos domínios reais em produção.
# -----------------------------------------------------------------------------
STORE_CORS=https://teste.mercadopreto.com.br
ADMIN_CORS=https://teste.mercadopreto.com.br
AUTH_CORS=https://teste.mercadopreto.com.br

# -----------------------------------------------------------------------------
# Storefront (Next.js) [OBRIGATÓRIO]
# NEXT_PUBLIC_* são compiladas no bundle do storefront durante o build da
# imagem — precisam estar preenchidas ANTES de `docker compose build storefront`.
# NEXT_PUBLIC_PUBLISHABLE_KEY e NEXT_PUBLIC_REGION_ID só existem depois que o
# backend sobe e roda o seed inicial (initial-data-seed.ts) — suba/semeie o
# backend primeiro, pegue os valores no Admin (Settings → API Keys /
# Regions) ou direto no banco, preencha aqui, e só então rode o build do
# storefront.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MEDUSA_URL=https://teste.mercadopreto.com.br/api
NEXT_PUBLIC_PUBLISHABLE_KEY=
NEXT_PUBLIC_REGION_ID=

# Chave pública (não o access token) do MercadoPago, usada pelo Payment
# Brick no checkout. Obter em: https://www.mercadopago.com.br/developers/pt/docs
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Let's Encrypt — TLS [OBRIGATÓRIO em produção]
# E-mail de registro, usado apenas para avisos de expiração de certificado.
# -----------------------------------------------------------------------------
LETSENCRYPT_EMAIL=admin@mercadopreto.com.br

# -----------------------------------------------------------------------------
# MercadoPago [OBRIGATÓRIO para checkout]
# Obter em: https://www.mercadopago.com.br/developers/pt/docs
# Em produção use o access token de produção (não o de teste)
# -----------------------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# URL pública do backend [OBRIGATÓRIO em produção]
# Usada para montar notification_url dos webhooks do MercadoPago e para
# montar a URL pública das imagens de produto re-hospedadas (file module).
# Nginx expõe a API sob /api/ no mesmo subdomínio do storefront (ver nginx.conf).
# -----------------------------------------------------------------------------
BACKEND_URL=https://teste.mercadopreto.com.br/api

# -----------------------------------------------------------------------------
# Focus NFe — fiscal [OPCIONAL]
# Sem token, NF-e não é emitida mas pedidos continuam funcionando.
# Obter em: https://focusnfe.com.br/
# -----------------------------------------------------------------------------
FOCUS_NFE_TOKEN=
# Deve bater com MARKETPLACE_SANDBOX (ver acima) — o backend recusa subir se não bater.
FOCUS_NFE_SANDBOX=true
FOCUS_NFE_CNPJ=
FOCUS_NFE_IE=
FOCUS_NFE_ADDRESS_STREET=
FOCUS_NFE_ADDRESS_NUMBER=
FOCUS_NFE_ADDRESS_DISTRICT=
FOCUS_NFE_ADDRESS_CITY=Cachoeira
FOCUS_NFE_ADDRESS_STATE=BA
FOCUS_NFE_ADDRESS_ZIP=44300000

# -----------------------------------------------------------------------------
# Melhor Envio [OPCIONAL]
# Sem token, retorna tarifas ilustrativas (PAC/SEDEX fixos).
# Obter token em: https://melhorenvio.com.br/painel/gerenciar/tokens
# CEP de origem: sede da MAB em Cachoeira/BA
# -----------------------------------------------------------------------------
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_ORIGIN_CEP=44300000

# -----------------------------------------------------------------------------
# Brevo — e-mail transacional [OPCIONAL]
# Sem API key, e-mails de aprovação de seller são ignorados.
# Obter em: https://app.brevo.com/settings/keys/api
# Em modo sandbox (ver MARKETPLACE_SANDBOX acima), todo e-mail é redirecionado
# para TEST_EMAIL_RECIPIENT em vez do destinatário real.
# -----------------------------------------------------------------------------
BREVO_API_KEY=
EMAIL_FROM=noreply@mercadopreto.com.br
TEST_EMAIL_RECIPIENT=

# -----------------------------------------------------------------------------
# Evolution API — WhatsApp [OPCIONAL]
# Notificações de pedido e aprovação via WhatsApp.
# Instância auto-hospedada no mesmo servidor ou externo.
# Em modo sandbox (ver MARKETPLACE_SANDBOX acima), toda mensagem é redirecionada
# para TEST_WHATSAPP_RECIPIENT em vez do número real.
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=
EVOLUTION_WEBHOOK_SECRET=
TEST_WHATSAPP_RECIPIENT=

# -----------------------------------------------------------------------------
# ClearSale — antifraude [OBRIGATÓRIO]
# O backend recusa subir sem essa variável (ver src/utils/validate-env.ts).
# Configure o webhook no painel ClearSale: POST /admin/webhooks/clearsale
# -----------------------------------------------------------------------------
CLEARSALE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Plausible — analytics [OPCIONAL]
# Proxy LGPD para analytics sem cookies. Sem config, retorna 204.
# -----------------------------------------------------------------------------
PLAUSIBLE_URL=
PLAUSIBLE_DOMAIN=teste.mercadopreto.com.br

# -----------------------------------------------------------------------------
# Comissão padrão [OPCIONAL]
# Fallback se não houver configuração salva no banco.
# Pode ser alterado em tempo real via PATCH /admin/settings
# -----------------------------------------------------------------------------
MARKETPLACE_COMMISSION_RATE=15
