# =============================================================================
# Mercado Preto — Backend (Medusa.js v2)
#
# LEGENDA:
#   [OBRIGATÓRIO] — a ausência desta var trava a inicialização do servidor
#   [OPCIONAL]    — sem o valor, a integração é desativada silenciosamente
#
# PRODUÇÃO:
#   - Nunca commite este arquivo. Adicione .env ao .gitignore.
#   - Use um gerenciador de segredos (AWS Secrets Manager, Doppler, Vault).
#   - Gere novos valores para todos os campos marcados como "(gerar em prod)".
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados [OBRIGATÓRIO]
#
# Formato: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Dev local: porta 5433 (mapeada pelo docker-compose do Postgres na 5432 interna)
# Produção:  postgres://USER:SENHA@rds-endpoint.amazonaws.com:5432/mercado_preto
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/mercado_preto

# -----------------------------------------------------------------------------
# Redis [OBRIGATÓRIO]
#
# Usado pelo Medusa para filas de eventos e cache de módulos.
# Dev local: porta 6380 (mapeada pelo docker-compose do Redis na 6379 interna)
# Produção:  redis://USER:SENHA@elasticache-endpoint.amazonaws.com:6379
# -----------------------------------------------------------------------------
REDIS_URL=redis://HOST:6379

# -----------------------------------------------------------------------------
# Segurança [OBRIGATÓRIO em produção]
#
# JWT_SECRET:    assina tokens de autenticação de admin/customer
# COOKIE_SECRET: assina cookies de sessão
#
# (gerar em prod) openssl rand -hex 32
# ATENÇÃO: trocar estes valores invalida todas as sessões ativas.
# -----------------------------------------------------------------------------
JWT_SECRET=                        # openssl rand -hex 32
COOKIE_SECRET=                     # openssl rand -hex 32

# -----------------------------------------------------------------------------
# CORS [OBRIGATÓRIO]
#
# STORE_CORS:  origens permitidas para o storefront (Next.js)
# ADMIN_CORS:  origens permitidas para o painel admin do Medusa
# AUTH_CORS:   origens permitidas para endpoints de autenticação
#
# Em produção: remova http://localhost:* e mantenha apenas os domínios reais.
# Múltiplas origens separadas por vírgula, sem espaços.
# -----------------------------------------------------------------------------
STORE_CORS=http://localhost:3000,https://teste.mercadopreto.com.br
ADMIN_CORS=http://localhost:9000,https://teste.mercadopreto.com.br
AUTH_CORS=http://localhost:3000,http://localhost:9000,https://teste.mercadopreto.com.br

# -----------------------------------------------------------------------------
# MercadoPago [OBRIGATÓRIO para checkout]
#
# REGRA CRÍTICA: public key e access token DEVEM ter o mesmo prefixo.
#   TEST-*   → sandbox (pagamentos simulados, cartões de teste)
#   APP_USR-* → produção (pagamentos reais)
#   Misturar prefixos causa erro 2006 (Card Token not found) ou erro 17.
#
# Obter em: https://www.mercadopago.com.br/developers/panel/app
#   → Selecione o app → Credenciais de teste / Credenciais de produção
#
# App atual: marketplace_mab (AppID: 3826759758051273)
# -----------------------------------------------------------------------------

# Access token SANDBOX (prefixo TEST-) — para desenvolvimento e testes
MERCADOPAGO_ACCESS_TOKEN=TEST-...   # sandbox

# Access token PRODUÇÃO (prefixo APP_USR-) — descomentar ao ir para produção
# Lembre de trocar também NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY no storefront .env.local
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-... # produção

# URL pública do backend — usada pelo MercadoPago para enviar notificações de pagamento.
# Em dev local: use um túnel HTTP (ngrok, Cloudflare Tunnel, localtunnel).
#   Exemplo: ngrok http 9000  →  BACKEND_URL=https://abc123.ngrok.io
# Em produção: URL real do servidor backend (ex: https://teste.mercadopreto.com.br/api)
BACKEND_URL=https://teste.mercadopreto.com.br/api

# Segredo do webhook do MercadoPago — valida que as notificações vêm do MP.
# Configurar em: MP Dashboard → Webhooks → "Chave secreta" (gerada pelo painel).
# (gerar em prod) o próprio painel MP gera este valor ao criar o webhook.
# Deixar vazio desativa a validação de assinatura (inseguro em produção).
MERCADOPAGO_WEBHOOK_SECRET=          # gerado pelo painel MP

# -----------------------------------------------------------------------------
# Focus NFe [OPCIONAL]
#
# Emite NF-e/NFS-e automaticamente ao confirmar pedidos.
# Sem FOCUS_NFE_TOKEN, a emissão fiscal é desativada silenciosamente.
#
# Obter token em: https://focusnfe.com.br → Dashboard → API Token
# FOCUS_NFE_SANDBOX=true  → ambiente de homologação (notas não têm validade fiscal)
# FOCUS_NFE_SANDBOX=false → produção (notas com validade fiscal — use com cuidado)
#
# Dados da empresa emissora (sede da MAB em Cachoeira/BA):
# -----------------------------------------------------------------------------
FOCUS_NFE_TOKEN=
FOCUS_NFE_SANDBOX=true
FOCUS_NFE_CNPJ=                        # CNPJ da empresa emissora (somente dígitos)
FOCUS_NFE_IE=                          # Inscrição Estadual (somente dígitos, ou ISENTO)
FOCUS_NFE_ADDRESS_STREET=              # Logradouro (ex: Rua das Flores)
FOCUS_NFE_ADDRESS_NUMBER=              # Número (ex: 123)
FOCUS_NFE_ADDRESS_DISTRICT=            # Bairro (ex: Centro)
FOCUS_NFE_ADDRESS_CITY=Cachoeira
FOCUS_NFE_ADDRESS_STATE=BA
FOCUS_NFE_ADDRESS_ZIP=44300000         # CEP somente dígitos

# -----------------------------------------------------------------------------
# Melhor Envio [OPCIONAL]
#
# Calcula fretes em tempo real (PAC, SEDEX, transportadoras parceiras).
# Sem MELHOR_ENVIO_TOKEN, retorna tarifas fixas ilustrativas como fallback.
#
# Obter token em: https://melhorenvio.com.br → Configurações → Tokens → Gerar token
# Escopo necessário: "shipping-calculate"
# O token expira — renovar antes da data de expiração visível no painel.
#
# MELHOR_ENVIO_ORIGIN_CEP: CEP de origem para cálculo de frete (sede MAB, Cachoeira/BA)
# -----------------------------------------------------------------------------
MELHOR_ENVIO_TOKEN=                  # JWT gerado em melhorenvio.com.br
MELHOR_ENVIO_ORIGIN_CEP=44300000

# -----------------------------------------------------------------------------
# Meilisearch [OPCIONAL]
#
# Busca full-text de produtos. Sem config, a busca usa o banco de dados como fallback.
# Dev local: container na porta 7701 (host) → 7700 (container)
# Produção: https://search.mercadopreto.com.br ou Meilisearch Cloud
#
# MEILISEARCH_API_KEY deve ser igual a MEILI_MASTER_KEY no docker-compose.
# Em produção use uma master key forte (openssl rand -hex 32) e crie
# search keys com escopo restrito para expor ao frontend.
# -----------------------------------------------------------------------------
MEILISEARCH_HOST=http://localhost:7701
MEILISEARCH_API_KEY=                # igual a MEILI_MASTER_KEY no docker-compose

# -----------------------------------------------------------------------------
# Brevo — e-mail transacional [OPCIONAL]
#
# Envia e-mails de confirmação de pedido, aprovação de vendedor, etc.
# Sem BREVO_API_KEY, os e-mails são ignorados silenciosamente.
#
# Obter em: https://app.brevo.com → SMTP & API → API Keys → Gerar nova chave
# EMAIL_FROM: endereço remetente — DEVE ser um domínio verificado no Brevo.
#   Em dev: pode usar gmail temporariamente (sem DKIM, cai em spam).
#   Em produção: configure SPF, DKIM e DMARC para o domínio mercadopreto.com.br.
# -----------------------------------------------------------------------------
BREVO_API_KEY=                      # obtido em app.brevo.com
EMAIL_FROM=noreply@mercadopreto.com.br

# -----------------------------------------------------------------------------
# Evolution API — gateway WhatsApp [OPCIONAL]
#
# Envia notificações WhatsApp nos eventos: order.placed, order.completed, order.shipment_created.
# Sem estas vars, as notificações WhatsApp são desativadas silenciosamente.
#
# FLUXO DE CONFIGURAÇÃO:
#   1. Suba o container: docker compose up -d evolution-api
#   2. Crie instância:   POST http://localhost:8080/instance/create
#   3. Escaneie o QR:    GET  http://localhost:8080/instance/connect/{instanceName}
#   4. Preencha EVOLUTION_API_INSTANCE com o nome da instância criada
#
# Em produção: EVOLUTION_API_URL deve ser a URL pública do Evolution API
#   e EVOLUTION_API_KEY deve ser trocada por um valor forte e aleatório.
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=mercadopreto_evo_key  # deve bater com docker-compose
EVOLUTION_API_INSTANCE=mercadopreto     # nome da instância criada e conectada via QR
EVOLUTION_WEBHOOK_SECRET=               # (opcional) valida webhooks recebidos do Evolution API

# -----------------------------------------------------------------------------
# ClearSale — antifraude [OPCIONAL]
#
# Valida assinatura dos webhooks recebidos da ClearSale.
# Sem esta var, o endpoint /webhooks/clearsale aceita qualquer POST (inseguro em prod).
# Obter o segredo no painel ClearSale ao configurar o webhook de notificação.
# -----------------------------------------------------------------------------
CLEARSALE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Plausible Analytics [OPCIONAL]
#
# O backend faz proxy de eventos do Plausible para evitar bloqueio por ad-blockers.
# Sem estas vars, o endpoint /store/analytics retorna 204 (sem erro, sem dados).
#
# PLAUSIBLE_URL: URL da instância Plausible (cloud: https://plausible.io ou self-hosted)
# PLAUSIBLE_DOMAIN: domínio cadastrado no Plausible (deve bater com o site configurado)
# -----------------------------------------------------------------------------
PLAUSIBLE_URL=
PLAUSIBLE_DOMAIN=teste.mercadopreto.com.br

# -----------------------------------------------------------------------------
# Comissão padrão do marketplace [OPCIONAL]
#
# Percentual de comissão cobrado sobre cada venda (ex: 15 = 15%).
# Este valor é o fallback quando não há configuração no banco de dados.
# Pode ser alterado em tempo real via PATCH /admin/settings sem reiniciar o servidor.
# -----------------------------------------------------------------------------
MARKETPLACE_COMMISSION_RATE=15

# -----------------------------------------------------------------------------
# Ambiente
#
# development: logs verbosos, recarregamento automático, sem minificação
# production:  logs reduzidos, sem dev server, otimizações ativas
# -----------------------------------------------------------------------------
NODE_ENV=development
