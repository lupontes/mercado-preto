# =============================================================================
# Mercado Preto — Backend (Medusa.js v2)
# Copie este arquivo para .env e preencha os valores antes de iniciar.
# Vars marcadas com [OBRIGATÓRIO] travam a inicialização se ausentes.
# Vars marcadas com [OPCIONAL] têm fallback ou desativam a integração.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados [OBRIGATÓRIO]
# Formato: postgres://usuario:senha@host:porta/banco
# Docker local (docker-compose.yml): porta mapeada em 5433
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://medusa:medusa@localhost:5433/mercado_preto

# -----------------------------------------------------------------------------
# Redis [OBRIGATÓRIO]
# Usado para cache, filas e sessões.
# Docker local: porta mapeada em 6380
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6380

# -----------------------------------------------------------------------------
# Segurança [OBRIGATÓRIO em produção]
# Gere valores aleatórios: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=troque_por_string_aleatoria_em_producao
COOKIE_SECRET=troque_por_outra_string_aleatoria_em_producao

# -----------------------------------------------------------------------------
# CORS — domínios autorizados [OBRIGATÓRIO]
# Múltiplos domínios separados por vírgula, sem espaços.
# STORE_CORS: storefront (clientes)
# ADMIN_CORS: painel administrativo Medusa
# AUTH_CORS: endpoints de autenticação (geralmente union dos dois)
# -----------------------------------------------------------------------------
STORE_CORS=http://localhost:3000,https://mercadopreto.com.br
ADMIN_CORS=http://localhost:9000,https://admin.mercadopreto.com.br
AUTH_CORS=http://localhost:3000,http://localhost:9000,https://mercadopreto.com.br

# -----------------------------------------------------------------------------
# MercadoPago — pagamentos e split [OBRIGATÓRIO para checkout]
# Obter em: https://www.mercadopago.com.br/developers/pt/docs
# Sandbox: use credenciais de teste do painel MP
# -----------------------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Focus NFe — emissão de NF-e / NFS-e [OPCIONAL]
# Sem este token, a emissão fiscal é desativada silenciosamente.
# Obter em: https://focusnfe.com.br/
# FOCUS_NFE_SANDBOX=true  → homologação (sandbox), false → produção
# -----------------------------------------------------------------------------
FOCUS_NFE_TOKEN=
FOCUS_NFE_SANDBOX=true

# CNPJ e Inscrição Estadual do emitente (MAB)
FOCUS_NFE_CNPJ=
FOCUS_NFE_IE=

# Endereço do emitente — necessário para gerar o XML da NF-e
FOCUS_NFE_ADDRESS_STREET=
FOCUS_NFE_ADDRESS_NUMBER=
FOCUS_NFE_ADDRESS_DISTRICT=
FOCUS_NFE_ADDRESS_CITY=Cachoeira
FOCUS_NFE_ADDRESS_STATE=BA
FOCUS_NFE_ADDRESS_ZIP=44300000

# -----------------------------------------------------------------------------
# Melhor Envio — cálculo de frete [OPCIONAL]
# Sem token, o sistema retorna tarifas ilustrativas (PAC/SEDEX fixos).
# Obter em: https://melhorenvio.com.br/painel/gerenciar/tokens
# MELHOR_ENVIO_ORIGIN_CEP: CEP do remetente padrão (sede da MAB em Cachoeira/BA)
# -----------------------------------------------------------------------------
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_ORIGIN_CEP=44300000

# -----------------------------------------------------------------------------
# Meilisearch — busca full-text [OPCIONAL]
# Sem esta configuração, a busca usa fallback no banco de dados.
# Docker local: http://localhost:7701 (porta mapeada de 7700)
# MEILISEARCH_API_KEY: mesma chave definida em MEILI_MASTER_KEY no Docker
# -----------------------------------------------------------------------------
MEILISEARCH_HOST=http://localhost:7701
MEILISEARCH_API_KEY=mercadopreto_search_key

# -----------------------------------------------------------------------------
# Brevo — e-mail transacional [OPCIONAL]
# Sem esta configuração, e-mails (ex: aprovação de seller) são silenciosamente ignorados.
# Obter em: https://app.brevo.com/settings/keys/api
# EMAIL_FROM: deve ser um domínio verificado no Brevo
# -----------------------------------------------------------------------------
BREVO_API_KEY=
EMAIL_FROM=noreply@mercadopreto.com.br

# -----------------------------------------------------------------------------
# Evolution API + WhatsApp [OPCIONAL]
# Sem estas vars, notificações WhatsApp são silenciosamente desativadas.
# Instância auto-hospedada — ver docker-compose.yml para Chatwoot/Evolution
# EVOLUTION_WEBHOOK_SECRET: validação de assinatura HMAC (pode deixar vazio)
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=
EVOLUTION_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# ClearSale — antifraude [OPCIONAL]
# Sem esta var, o webhook do ClearSale não valida assinatura (aceita qualquer POST).
# Configure o webhook no painel ClearSale apontando para /admin/webhooks/clearsale
# CLEARSALE_WEBHOOK_SECRET: string secreta compartilhada com a ClearSale
# -----------------------------------------------------------------------------
CLEARSALE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Plausible Analytics — proxy LGPD [OPCIONAL]
# Sem estas vars, o proxy /store/analytics retorna 204 sem fazer nada.
# Instância auto-hospedada ou plausible.io
# -----------------------------------------------------------------------------
PLAUSIBLE_URL=
PLAUSIBLE_DOMAIN=mercadopreto.com.br

# -----------------------------------------------------------------------------
# Comissão padrão do marketplace [OPCIONAL]
# Fallback quando não há configuração salva no banco (tabela marketplace_config).
# O valor pode ser alterado via PATCH /admin/settings sem reiniciar o servidor.
# -----------------------------------------------------------------------------
MARKETPLACE_COMMISSION_RATE=15

# -----------------------------------------------------------------------------
# URL pública do backend [OBRIGATÓRIO em produção]
# Usada para montar notification_url dos webhooks do MercadoPago e para
# montar a URL pública das imagens de produto re-hospedadas (file module).
# Dev local: use um túnel (ex: ngrok http 9000) ou deixe vazio.
# -----------------------------------------------------------------------------
BACKEND_URL=https://api.mercadopreto.com.br

# -----------------------------------------------------------------------------
# Nuvemshop — migração única do catálogo da MAB [uso pontual]
# App privado criado em partners.tiendanube.com (App ID 35695).
# Ver docs/superpowers/specs/2026-07-02-nuvemshop-migration-design.md
# -----------------------------------------------------------------------------
NUVEMSHOP_ACCESS_TOKEN=
NUVEMSHOP_STORE_ID=

# -----------------------------------------------------------------------------
# Ambiente
# development | production | test
# -----------------------------------------------------------------------------
NODE_ENV=development
